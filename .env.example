# Copy this file to .env and fill in your values
# Get a Gemini API key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional: set a bearer token to protect the app
APP_TOKEN=
# Rate limiting: max POST/DELETE requests per window per IP (0 = disabled)
RATE_LIMIT_MAX=30
RATE_LIMIT_WINDOW=60

# Wizi (Wiz) integration — service account with READ permissions
WIZI_CLIENT_ID=
WIZI_CLIENT_SECRET=
WIZI_AUTH_URL=https://auth.app.wiz.io/oauth/token
WIZI_API_URL=https://api.il1.app.wiz.io/graphql
